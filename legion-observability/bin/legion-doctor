#!/usr/bin/env bash
# Resolve this script's real location even when invoked through a symlink
# (e.g. the ~/.agents/bin farm created by scripts/install.sh). Bash does not
# dereference $0 for symlinks, so a naive "dirname $0/.." lands in the wrong
# directory; walk BASH_SOURCE through any symlink chain first.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
root="$(cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd)"
exec "$root/scripts/legion-doctor.sh" "$@"
