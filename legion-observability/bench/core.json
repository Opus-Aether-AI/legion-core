{
  "schema": "legion.bench.suite.v1",
  "suite": "core",
  "description": "Deterministic Legion harness benchmark for routing, validation, trigger regressions, and self-improvement workflows.",
  "gate": {
    "allow_neutral": true,
    "max_false_success_delta": 0
  },
  "cases": [
    {
      "id": "eval.plugin.observability",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Observability prompts should route to legion-observability.",
      "scope": "plugin",
      "prompt": "Show per-executor cost success latency spans and self-learning reports for Legion.",
      "expect_type": "plugin",
      "expect": "legion-observability",
      "expect_not": "legion-router",
      "required": true
    },
    {
      "id": "eval.plugin.router",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Delegation prompts should route to legion-router.",
      "scope": "plugin",
      "prompt": "Delegate this coding task to Codex in an isolated worktree and bring back a metered diff.",
      "expect_type": "plugin",
      "expect": "legion-router",
      "expect_not": "legion-observability",
      "required": true
    },
    {
      "id": "route.frontend-review",
      "type": "route",
      "dimension": "routing",
      "summary": "Frontend review runs on Fable via Claude Code (verify-by-screenshot, a different Claude lens than the Opus polish), read-only. Claude models never go through Cursor.",
      "archetype": "frontend-review",
      "expect": {
        "executor": "claude",
        "model_ref": "claude_default",
        "sandbox": "read-only",
        "reasoning_effort": "high"
      },
      "required": true
    },
    {
      "id": "route.docs-edit",
      "type": "route",
      "dimension": "routing",
      "summary": "Docs edits use the Codex workhorse (GPT-5.6) at max effort.",
      "archetype": "docs-edit",
      "expect": {
        "executor": "codex",
        "model_ref": "codex_workhorse",
        "sandbox": "workspace-write",
        "reasoning_effort": "max"
      },
      "required": true
    },
    {
      "id": "doctor.marketplace-schema",
      "type": "doctor",
      "dimension": "validation",
      "summary": "Marketplace schema must stay valid.",
      "only": "marketplace-schema",
      "required": true
    },
    {
      "id": "doctor.telemetry-schema",
      "type": "doctor",
      "dimension": "validation",
      "summary": "Telemetry span schema must stay present and valid.",
      "only": "telemetry-schema",
      "required": true
    },
    {
      "id": "doctor.descriptions",
      "type": "doctor",
      "dimension": "validation",
      "summary": "Skill descriptions must stay line-readable.",
      "only": "descriptions",
      "required": true
    },
    {
      "id": "task.session-correction-learning",
      "type": "task",
      "dimension": "self-learning",
      "summary": "Explicit user corrections in session logs should become self-learning outcomes.",
      "target_type": "plugin",
      "target_name": "legion-observability",
      "files": {
        "home/.codex/sessions/legion/session.jsonl": "{\"payload\":{\"type\":\"user_message\",\"content\":\"u should have linked the right harness bench repo, wrong attribution source\"}}\n"
      },
      "command": [
        "{repo}/legion-observability/bin/legion-session-learn",
        "--home",
        "{home}",
        "--logs",
        "{logs}",
        "--lookback-days",
        "30",
        "--record",
        "--json"
      ],
      "validators": [
        {
          "type": "stdout_json_field_equals",
          "field": "candidates.0.category",
          "equals": "user-correction-feedback"
        },
        {
          "type": "stdout_json_field_equals",
          "field": "recorded.0.source",
          "equals": "session-learn"
        },
        {
          "type": "jsonl_contains",
          "path": "{logs}/self-learn/outcomes.jsonl",
          "match": {
            "source": "session-learn",
            "target_type": "plugin",
            "target_name": "legion-observability",
            "metadata": {
              "category": "user-correction-feedback"
            }
          }
        }
      ],
      "required": true
    },
    {
      "id": "task.self-learning-memory",
      "type": "task",
      "dimension": "self-learning",
      "summary": "Recorded benchmark outcomes should synthesize durable self-learning memory.",
      "target_type": "plugin",
      "target_name": "legion-observability",
      "files": {
        "logs/self-learn/outcomes.jsonl": "{\"schema\":\"legion.outcome.v1\",\"id\":\"bench-memory-fixture\",\"ts\":\"2026-06-27T00:00:00Z\",\"source\":\"legion-bench\",\"target_type\":\"plugin\",\"target_name\":\"legion-observability\",\"severity\":\"medium\",\"summary\":\"Benchmark fixture should become a durable memory hint.\",\"evidence\":\"bench fixture\",\"run_id\":\"bench-fixture\",\"source_path\":\"\",\"metadata\":{\"suite\":\"core\",\"case_id\":\"task.self-learning-memory\"}}\n"
      },
      "command": [
        "{repo}/legion-observability/bin/legion-self-learn",
        "run",
        "--repo",
        "{repo}",
        "--logs",
        "{logs}",
        "--apply-memory",
        "--json"
      ],
      "validators": [
        {
          "type": "stdout_json_field_equals",
          "field": "summary.outcomes",
          "equals": 1
        },
        {
          "type": "file_exists",
          "path": "{logs}/self-learn/harness-memory.json"
        },
        {
          "type": "json_file_field_equals",
          "path": "{logs}/self-learn/harness-memory.json",
          "field": "entities.plugin:legion-observability.target_name",
          "equals": "legion-observability"
        }
      ],
      "required": true
    },
    {
      "id": "task.doctor-negative-fixture",
      "type": "task",
      "dimension": "validation",
      "summary": "Doctor should reject a fixture with a block-scalar skill description.",
      "target_type": "plugin",
      "target_name": "legion-observability",
      "files": {
        "bad/SKILL.md": "---\nname: bad-skill\ndescription: >\n  This block scalar should fail line-readable description checks.\n---\n"
      },
      "env": {
        "LEGION_ROOT": "{workspace}/bad"
      },
      "command": [
        "{repo}/legion-observability/bin/legion-doctor",
        "--repo",
        "{workspace}/bad",
        "--only",
        "descriptions"
      ],
      "expect_exit": 1,
      "validators": [
        {
          "type": "stdout_contains",
          "text": "FAIL"
        },
        {
          "type": "stdout_contains",
          "text": "block-scalar description"
        }
      ],
      "required": true
    },
    {
      "id": "task.code-intel-typescript-diagnostics",
      "type": "task",
      "dimension": "code-intelligence",
      "summary": "Code intelligence should catch TypeScript diagnostics and emit a Legion artifact.",
      "target_type": "plugin",
      "target_name": "legion-code-intel",
      "files": {
        "fake-tsc": "#!/usr/bin/env bash\necho \"src/bad.ts(1,14): error TS2322: Type 'string' is not assignable to type 'number'.\"\nexit 2\n",
        "tsconfig.json": "{\"compilerOptions\":{\"strict\":true}}\n",
        "src/bad.ts": "export const n: number = \"no\";\n"
      },
      "command": [
        "bash",
        "-lc",
        "chmod +x ./fake-tsc && LEGION_TSC_BIN=./fake-tsc {repo}/legion-code-intel/bin/legion-code-intel diagnostics --repo . --adapter typescript --emit-span --json"
      ],
      "expect_exit": 1,
      "validators": [
        {
          "type": "stdout_json_field_equals",
          "field": "schema",
          "equals": "legion.code-intel.v1"
        },
        {
          "type": "stdout_json_field_equals",
          "field": "status",
          "equals": "failed"
        },
        {
          "type": "stdout_json_field_equals",
          "field": "summary.errors",
          "equals": 1
        },
        {
          "type": "stdout_json_field_equals",
          "field": "diagnostics.0.code",
          "equals": "TS2322"
        }
      ],
      "required": true
    }
  ]
}
