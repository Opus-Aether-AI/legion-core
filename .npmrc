# The @opus-aether-ai scope is published to GitHub Packages (private), not npmjs.
# This maps the scope to the right registry. Authentication is per-consumer and
# must NOT be committed — add the auth line to your own ~/.npmrc or CI env:
#
#   //npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
#
# where GITHUB_TOKEN is a token with `read:packages` (consumers) or
# `write:packages` (publishers). See README → "Install as a package".
@opus-aether-ai:registry=https://npm.pkg.github.com
