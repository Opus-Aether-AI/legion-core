#!/usr/bin/env bash
# Mock for `claude` CLI. Supports both plugin-management commands used by
# install/refresh/uninstall tests and headless `claude -p` JSON mode used by
# legion-claude tests.

set -euo pipefail

[[ -n "${MOCK_CALL_LOG:-}" ]] && printf 'claude %s\n' "$*" >> "$MOCK_CALL_LOG"

MOCK_STATE_FILE="$HOME/.mock-claude-marketplaces"

if [[ "${1:-}" == "-p" ]]; then
    cat >/dev/null || true
    if [[ "${MOCK_CLAUDE_LIMIT:-0}" == "1" ]]; then
        printf '%s\n' '{"is_error":true,"result":"You have reached your usage limit"}'
        exit 0
    fi
    if [[ "${MOCK_CLAUDE_FAIL:-0}" == "1" ]]; then
        printf 'error\n' >&2
        exit 1
    fi
    printf '%s\n' '{"type":"result","is_error":false,"result":"CLAUDE_OK_OUTPUT","total_cost_usd":0.12,"usage":{"input_tokens":1000,"output_tokens":50}}'
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "marketplace" && "${3:-}" == "list" ]]; then
    [[ -f "$MOCK_STATE_FILE" ]] && cat "$MOCK_STATE_FILE"
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "marketplace" && "${3:-}" == "add" ]]; then
    printf 'legion-core\n' >> "$MOCK_STATE_FILE"
    printf 'added marketplace: %s\n' "${4:-}"
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "marketplace" && "${3:-}" == "update" ]]; then
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "marketplace" && "${3:-}" == "remove" ]]; then
    if [[ -f "$MOCK_STATE_FILE" ]]; then
        grep -vF "${4:-}" "$MOCK_STATE_FILE" > "$MOCK_STATE_FILE.tmp" || true
        mv "$MOCK_STATE_FILE.tmp" "$MOCK_STATE_FILE"
    fi
    printf 'removed marketplace: %s\n' "${4:-}"
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "install" ]]; then
    printf '✔ Successfully installed plugin: %s\n' "${3:-}"
    plugin_name="${3%@*}"
    mkdir -p "$HOME/.claude/plugins/cache/legion-core/$plugin_name/0.1.0"
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "uninstall" ]]; then
    printf '✔ Successfully uninstalled: %s\n' "${3:-}"
    rm -rf "$HOME/.claude/plugins/cache/legion-core/${3%@*}"
    exit 0
fi

if [[ "${1:-}" == "plugin" && "${2:-}" == "list" ]]; then
    for d in "$HOME/.claude/plugins/cache/legion-core/"*/; do
        [[ -d "$d" ]] || continue
        name="$(basename "$d")"
        printf '❯ %s@legion-core\n' "$name"
        printf '  Version: 0.1.0\n'
        printf '  Scope: user\n'
    done
    exit 0
fi

exit 0
