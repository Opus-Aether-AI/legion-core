{
  "schema": "legion.bench.suite.v1",
  "suite": "legion-run",
  "description": "Deterministic no-spend benchmark for the direct legion-run heavy-task path: plan command plus validate command, a real fixture coding task, full lifecycle, and self-learning evidence.",
  "cases": [
    {
      "id": "task.legion-run-direct-plan-validate",
      "type": "task",
      "dimension": "orchestration",
      "summary": "Direct legion-run mode should execute a real FieldOps triage coding task from plan/validate commands and write the full evidence contract.",
      "target_type": "command",
      "target_name": "legion-run",
      "command": [
        "bash",
        "{repo}/legion-observability/bench/adapters/legion-run-direct-smoke.sh",
        "{repo}"
      ],
      "timeout": 180,
      "validators": [
        {
          "type": "stdout_json_field_equals",
          "field": "ok",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "mode",
          "equals": "direct"
        },
        {
          "type": "stdout_json_field_equals",
          "field": "profile",
          "equals": "legion.heavy_task.v1"
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.required_artifacts_present",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.all_stages_passed",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.plan_command_used",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.default_slices_generated",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.routes_generated_for_all_slices",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.fanout_apply_ran",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.final_review_ran",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.validate_command_used",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.coding_task_implemented",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.default_eval_used",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.report_and_share_ran",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.hints_consumed",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.self_learning_recorded",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.self_learning_memory_applied",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.validation_feedback_recorded",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.self_learning_memory_updated_by_validation_feedback",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.html_reports_generated",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.heal_plan_ran",
          "equals": true
        },
        {
          "type": "stdout_json_field_equals",
          "field": "checks.stage_order_preserved",
          "equals": true
        },
        {
          "type": "file_exists",
          "path": "{workspace}/direct-run-result.json"
        },
        {
          "type": "file_exists",
          "path": "{workspace}/legion-run-direct-benchmark.html"
        },
        {
          "type": "file_contains",
          "path": "{workspace}/legion-run-direct-benchmark.html",
          "text": "Validation-Discovered Learning"
        },
        {
          "type": "file_contains",
          "path": "{workspace}/legion-run-direct-benchmark.html",
          "text": "Legion run report"
        }
      ],
      "required": true
    }
  ]
}
