#!/usr/bin/env bash
# Resolve through the ~/.agents/bin symlink (see #81) so the wrapper finds its
# real plugin dir, not the symlink's location.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
root="$(cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd)"
exec python3 "$root/scripts/legion-catalog.py" "$@"
