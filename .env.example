# legion-core runtime configuration (copy to .env or export in your shell)

# Anthropic (Claude executors). Required for claude-routed work.
ANTHROPIC_API_KEY=

# MiniMax (optional extra provider; minimax-* models fall back to Anthropic if unset)
MINIMAX_AUTH_TOKEN=

# Where this core is published (used by the installer; override per fork)
LEGION_REPO=Opus-Aether-AI/legion-core

# Telemetry sink (defaults to ~/.claude/logs/legion/spans/)
# LEGION_TELEMETRY_DIR=

# OTLP export endpoint (optional; legion-otel-export is a no-op until set)
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Router port (legion-router proxy)
# ROUTER_PORT=8082
