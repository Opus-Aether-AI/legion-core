{
  "schema": "legion.bench.suite.v1",
  "suite": "stable",
  "description": "Comprehensive deterministic Legion benchmark for stable PR and release gating. Extends core with full routing policy coverage, plugin/entity trigger checks, doctor checks, and CLI artifact contracts.",
  "extends": [
    "core"
  ],
  "gate": {
    "allow_neutral": true,
    "max_false_success_delta": 0
  },
  "cases": [
    {
      "id": "eval.plugin.setup",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Install/update prompts should route to legion-setup.",
      "scope": "plugin",
      "prompt": "Install Legion into Claude Code, Codex, and Cursor, wire the marketplace, and set up daily refresh.",
      "expect_type": "plugin",
      "expect": "legion-setup",
      "expect_not": "legion-router",
      "required": true
    },
    {
      "id": "eval.plugin.orchestrate",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Parallel multi-model delivery prompts should route to legion-orchestrate.",
      "scope": "plugin",
      "prompt": "Orchestrate this feature with Legion: decompose, fan out implementation slices, cross-model verify, and synthesize.",
      "expect_type": "plugin",
      "expect": "legion-orchestrate",
      "expect_not": "legion-observability",
      "required": true
    },
    {
      "id": "eval.plugin.codex-mode",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Codex-primary routing prompts should route to legion-codex-mode.",
      "scope": "plugin",
      "prompt": "I am running Legion under Codex CLI and need to know when to call Claude for deep architecture or final review.",
      "expect_type": "plugin",
      "expect": "legion-codex-mode",
      "expect_not": "legion-router",
      "required": true
    },
    {
      "id": "eval.entity.skill-observability",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Entity trigger should find the observability skill.",
      "scope": "entity",
      "prompt": "Did this harness change improve? Show bench results, doctor status, telemetry spans, and self-learning hints.",
      "expect_type": "skill",
      "expect": "legion-observability",
      "required": true
    },
    {
      "id": "eval.entity.skill-router",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Entity trigger should find the router skill.",
      "scope": "entity",
      "prompt": "Delegate a scoped coding task to Codex or Cursor in an isolated worktree and return a metered diff.",
      "expect_type": "skill",
      "expect": "legion-router",
      "required": true
    },
    {
      "id": "eval.entity.skill-orchestrate",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Entity trigger should find the orchestrator skill.",
      "scope": "entity",
      "prompt": "Fan out implementation slices across models in parallel, then cross-model verify and integrate the result.",
      "expect_type": "skill",
      "expect": "legion-orchestrate",
      "required": true
    },
    {
      "id": "eval.entity.skill-setup",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Entity trigger should find the setup skill.",
      "scope": "entity",
      "prompt": "Set up Legion on a new machine, install marketplace plugins, shared CLIs, Codex bridge, Cursor bridge, and refresh cron.",
      "expect_type": "skill",
      "expect": "legion-setup",
      "required": true
    },
    {
      "id": "eval.entity.skill-codex-mode",
      "type": "eval",
      "dimension": "triggering",
      "summary": "Entity trigger should find the Codex-mode skill.",
      "scope": "entity",
      "prompt": "Under Codex CLI decide when GPT should call Claude for architecture, frontend polish, final review, or a tie break.",
      "expect_type": "skill",
      "expect": "legion-codex-mode",
      "required": true
    },
    {
      "id": "route.orchestrate",
      "type": "route",
      "dimension": "routing",
      "summary": "High-level orchestration stays on Opus.",
      "archetype": "orchestrate",
      "expect": {
        "executor": "self",
        "model": "opus",
        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
      "id": "route.architecture-decision",
      "type": "route",
      "dimension": "routing",
      "summary": "Architecture decisions stay on Opus.",
      "archetype": "architecture-decision",
      "expect": {
        "executor": "self",
        "model": "opus",
        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
      "id": "route.deep-reasoning",
      "type": "route",
      "dimension": "routing",
      "summary": "Deep reasoning stays on Opus.",
      "archetype": "deep-reasoning",
      "expect": {
        "executor": "self",
        "model": "opus",
        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
      "id": "route.implement-feature",
      "type": "route",
      "dimension": "routing",
      "summary": "Feature implementation uses GPT-5.4 workspace write.",
      "archetype": "implement-feature",
      "expect": {
        "executor": "codex",
        "model": "gpt-5.4",
        "sandbox": "workspace-write",
        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
