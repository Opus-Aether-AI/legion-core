#!/usr/bin/env bash
# Resolve this script's real location even when invoked through the ~/.agents/bin
# symlink farm created by scripts/install.sh.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
root="$(cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd)"
exec bash "$root/scripts/legion-heal.sh" "$@"
