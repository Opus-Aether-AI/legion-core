        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
      "id": "route.migration",
      "type": "route",
      "dimension": "routing",
      "summary": "Migrations use GPT-5.4 workspace write.",
      "archetype": "migration",
      "expect": {
        "executor": "codex",
        "model": "gpt-5.4",
        "sandbox": "workspace-write",
        "reasoning_effort": "xhigh"
      },
      "required": true
    },
    {
      "id": "route.final-review",
      "type": "route",
      "dimension": "routing",
      "summary": "Final review uses GPT-5.5 read-only.",
      "archetype": "final-review",
      "expect": {
        "executor": "codex",
        "model": "gpt-5.5",
        "sandbox": "read-only",
        "reasoning_effort": "xhigh"
      },
      "required": true
