#!/usr/bin/env bash
# Mock for curl. Records calls and serves the marketplace fixture for install.sh
# tests that intentionally remove the local source clone.

set -euo pipefail

echo "curl $*" >> "${MOCK_CALL_LOG:-/dev/null}"

url="${@: -1}"
case "$url" in
    *".claude-plugin/marketplace.json")
        if [ -n "${MOCK_CURL_FIXTURE:-}" ] && [ -f "$MOCK_CURL_FIXTURE" ]; then
            cat "$MOCK_CURL_FIXTURE"
            exit 0
        fi
        ;;
    *"scripts/install.sh")
        if [ -n "${INSTALL_SH:-}" ] && [ -f "$INSTALL_SH" ]; then
            cat "$INSTALL_SH"
            exit 0
        fi
        ;;
esac

echo "mock curl: no fixture for $url" >&2
exit 22
